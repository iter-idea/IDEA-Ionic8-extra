{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "module",
      "description": "The module to build",
      "type": "promptString",
      "default": "common"
    },
    {
      "id": "versionBump",
      "description": "The type of version bump",
      "type": "pickString",
      "options": ["patch", "minor", "major"],
      "default": "patch"
    }
  ],
  "tasks": [
    {
      "label": "Build all modules",
      "detail": "npm run build:all — builds every module in dependency order (common and uncommon first)",
      "type": "shell",
      "command": "npm run build:all",
      "group": { "kind": "build", "isDefault": true },
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Build a module",
      "detail": "ng build <module> — build its @idea-ionic/* dependencies first",
      "type": "shell",
      "command": "ng",
      "args": ["build", "${input:module}"],
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "npm run lint",
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "npm run format",
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Publish a new version",
      "type": "shell",
      "command": "./publish.sh",
      "args": ["${input:versionBump}"],
      "group": "build",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
